[submodule "config"]
	path = config
	url = https://github.com/SpineEventEngine/config
[submodule "docs/_examples"]
	path = docs/_examples
	url = https://github.com/spine-examples/hello-validation
[submodule "docs/_time"]
	path = docs/_time
	url = https://github.com/SpineEventEngine/time
[submodule ".agents/shared"]
	path = .agents/shared
	url = https://github.com/SpineEventEngine/agents.git
	branch = master
	update = merge
	ignore = all
